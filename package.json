{
  "name": "thronerp-backend",
  "version": "0.1.0",
  "description": "Backend para ThroneRP: plataforma de roleplay narrativo con IA y memoria persistente.",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node --watch --env-file=.env src/server.js",
    "start": "node --env-file=.env src/server.js",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "node --check src/server.js",
    "vector-index": "node --env-file=.env scripts/create-vector-index.js",
    "seed:models": "node --env-file=.env scripts/seed-models.js"
  },
  "keywords": [
    "rpg",
    "roleplay",
    "ai",
    "narrative",
    "fastify",
    "mongodb"
  ],
  "author": "ThroneRP",
  "license": "UNLICENSED",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@fastify/websocket": "^10.0.1",
    "better-auth": "^1.1.0",
    "fastify": "^4.28.1",
    "mongodb": "^6.10.0",
    "mongoose": "^8.8.0",
    "openai": "^4.73.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.15.0",
    "mongodb-memory-server": "^11.2.0",
    "prettier": "^3.4.0",
    "vitest": "^4.1.8"
  }
}
