# =========================================================
# ThroneRP Backend - Variables de entorno
# Copia este archivo a .env y rellena los valores.
# =========================================================

# --- Servidor ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# --- Frontend (para CORS y Better-Auth) ---
FRONTEND_URL=http://localhost:5173

# --- Base de datos ---
# Opcion A: MongoDB Atlas (recomendado para produccion, free tier M0 incluye Vector Search)
# Obtener en https://www.mongodb.com/cloud/atlas
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/thronerp?retryWrites=true&w=majority
#
# Opcion B: MongoDB local para desarrollo (sin Vector Search, pero suficiente para pruebas basicas)
# docker run -d --name mongo -p 27017:27017 mongo:7
MONGODB_URI=mongodb://localhost:27017/thronerp
MONGODB_DB_NAME=thronerp

# --- Autenticación (Better-Auth) ---
# Genera con: openssl rand -base64 32
BETTER_AUTH_SECRET=cambiame_con_openssl_rand_base64_32
BETTER_AUTH_URL=http://localhost:3000

# OAuth opcional (Google / Discord)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# =========================================================
# Proveedores de IA (todos OpenAI-compatible)
# Solo configura los que vayas a usar.
# =========================================================

# --- Modelo por defecto para narración ---
# Opciones: deepseek | qwen | kimi | glm | mimo | llama
DEFAULT_NARRATION_PROVIDER=deepseek
DEFAULT_NARRATION_MODEL=deepseek-chat

# --- Modelo por defecto para embeddings (memoria semántica) ---
# Recomendado: qwen (text-embedding-v3, 1024 dim) o deepseek
DEFAULT_EMBEDDING_PROVIDER=qwen
DEFAULT_EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1024

# --- DeepSeek ---
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Qwen (Alibaba DashScope, modo compatible OpenAI) ---
# https://dashscope.console.aliyun.com/
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- Kimi / Moonshot ---
# https://platform.moonshot.ai/
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1

# --- GLM (Zhipu AI) ---
# https://open.bigmodel.cn/
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# --- MiMo (Xiaomi) ---
# Acceso vía OpenRouter o despliegue propio.
MIMO_API_KEY=
MIMO_BASE_URL=https://openrouter.ai/api/v1

# --- Llama 4 (vía Groq, gratis y rápido) ---
# https://console.groq.com/
LLAMA_API_KEY=
LLAMA_BASE_URL=https://api.groq.com/openai/v1

# =========================================================
# Configuración de memoria RPG
# =========================================================
# Mensajes recientes incluidos directos en el prompt
MEMORY_RECENT_WINDOW=20
# Memorias semánticas (RAG) recuperadas por turno
MEMORY_RAG_TOP_K=5
# Tokens antes de auto-resumir bloques antiguos
MEMORY_SUMMARIZE_THRESHOLD=4000
